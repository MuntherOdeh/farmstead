# ── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres connection string. Locally: copy from the Neon console.
# On Vercel: injected automatically by the Neon Marketplace integration.
DATABASE_URL=

# ── Auth (Better Auth) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of the app. Local dev: http://localhost:3000. Prod: the vercel.app URL.
BETTER_AUTH_URL=http://localhost:3000

# ── Seed admin account ───────────────────────────────────────────────────────
# Created on first run if it doesn't exist. The password is hashed before it
# touches the database and is never logged. Change it afterwards in /settings.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
